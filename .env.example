# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# MCA portal login (from your NoE confirmation email)
MCA_SDS_NUMBER=your-seafarer-reference-number
MCA_DOB=DD/MM/YYYY

# Resend (https://resend.com) — free tier is fine
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Where to send alerts
NOTIFY_EMAIL=dorhalevi95@gmail.com

# The date of your current booking (alerts fire if something earlier appears)
TARGET_DATE=2025-11-25
